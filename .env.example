# Root-level environment file for Docker Compose.
# Copy to .env before running `docker compose up`.
# For local backend development (uvicorn outside Docker), use backend/.env.example instead.

# Postgres container credentials. Used by docker-compose.yml to provision the postgres service.
POSTGRES_DB=voteme
POSTGRES_USER=voteme
POSTGRES_PASSWORD=changeme

# Backend connects to postgres by service name inside the docker network.
DATABASE_URL=postgresql+asyncpg://voteme:changeme@postgres:5432/voteme

# Auth
JWT_SECRET=changeme_replace_with_64_char_secret
APP_SALT=changeme_replace_with_random_salt
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Blockchain (Ethereum Sepolia)
BACKEND_PRIVATE_KEY=changeme_replace_with_eth_private_key
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/changeme
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
