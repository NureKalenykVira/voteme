# Root-level environment file for Docker Compose.
# Copy to .env before running `docker compose up`.
# For local backend development (uvicorn outside Docker), use backend/.env.example instead.

# Postgres container credentials. Used by docker-compose.yml to provision the postgres service.
POSTGRES_DB=voteme
POSTGRES_USER=voteme
POSTGRES_PASSWORD=your_postgres_password

# Backend connects to postgres by service name inside the docker network.
DATABASE_URL=postgresql+asyncpg://voteme:your_postgres_password@postgres:5432/voteme

# Auth
JWT_SECRET=generate_64_char_hex_with_openssl_rand
APP_SALT=generate_32_char_hex_with_openssl_rand
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Blockchain (Ethereum Sepolia) — backend runtime signer used by FastAPI to send transactions.
BACKEND_PRIVATE_KEY=changeme_replace_with_eth_private_key
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/changeme
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Blockchain (Sepolia testnet) — used by Hardhat to deploy VoteRegistry contract from contracts/.
# SEPOLIA_RPC_URL above is reused by Hardhat at deploy time (Alchemy/Infura HTTPS endpoint).
# DEPLOYER_PRIVATE_KEY is the wallet that pays gas for the one-time deploy; must be funded with Sepolia ETH.
# VOTEME_CONTRACT_ADDRESS is filled in after running `npx hardhat run scripts/deploy.ts --network sepolia`.
DEPLOYER_PRIVATE_KEY=
VOTEME_CONTRACT_ADDRESS=

# CORS — origins allowed by the backend.
# JSON array format required (pydantic reads list[str] from env as JSON).
# Both values needed: 4200 for local `npm start` dev, 80 for Docker frontend.
CORS_ORIGINS=["http://localhost:4200","http://localhost"]

# Frontend URL — used for email links (password reset, email confirmation).
FRONTEND_URL=http://localhost
