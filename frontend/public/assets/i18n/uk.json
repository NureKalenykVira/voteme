    "groups": {
      "gettingStarted": {
        "topic": "Початок роботи",
        "q1": { "q": "Що таке VoteMe?", "a": "VoteMe — це електронна платформа для голосування на основі блокчейну, розроблена для корпоративних, освітніх і громадських цілей. Вона записує криптографічні зобов'язання голосів і хеші результатів у тестовій мережі Ethereum Sepolia, щоб кожен міг незалежно перевірити, що результати не були підроблені." },
        "q2": { "q": "Хто може користуватися VoteMe?", "a": "VoteMe підтримує чотири ролі: організатори створюють вибори та керують ними; виборці голосують у виборах, до яких їх запрошено; аудитори мають доступ лише для читання результатів і журналів аудиту; глобальні адміністратори керують налаштуваннями платформи. Неавторизовані користувачі можуть перевіряти результати через публічний журнал аудиту." },
        "q3": { "q": "Як створити обліковий запис?", "a": "Натисніть «Почати» на головній сторінці та введіть ім'я, електронну адресу і пароль. Після надсилання форми реєстрації ви отримаєте листа з підтвердженням — перейдіть за посиланням у листі, щоб активувати обліковий запис перед входом." }
      },
      "forVoters": {
        "topic": "Для виборців",
        "q1": { "q": "Як приєднатися до виборів?", "a": "Організатори можуть запросити вас через пряме посилання, код запрошення або QR-код. Введіть код запрошення на сторінці приєднання, відскануйте QR-код або перейдіть за отриманим посиланням — усі три способи ведуть прямо до бюлетеня." },
        "q2": { "q": "Як проголосувати?", "a": "Відкрийте бюлетень, виберіть бажаний варіант і перейдіть до кроку попереднього перегляду, де можна перевірити свій вибір перед підтвердженням. Після підтвердження голос надсилається і фіксується. Процес складається з трьох кроків: вибір, перегляд, підтвердження." },
        "q3": { "q": "Чи можна змінити голос після надсилання?", "a": "Ні. Після надсилання голос є остаточним і не може бути змінений або відкликаний. Це забезпечується як на рівні бази даних (унікальне обмеження одного голосу на виборця на вибори), так і на рівні смарт-контракту в блокчейні." },
        "q4": { "q": "Чи можна проголосувати більше одного разу?", "a": "Ні. Система суворо дотримується правила: один голос на людину на одні вибори. Якщо ви спробуєте проголосувати повторно, бекенд відхилить запит із помилкою конфлікту, а інтерфейс покаже повідомлення «Ви вже проголосували»." }
      },
      "forOrganizers": {
        "topic": "Для організаторів",
        "q1": { "q": "Як створити вибори?", "a": "Увійдіть з обліковим записом організатора, перейдіть до розділу «Вибори» і натисніть «Створити голосування». Введіть назву, опис, дату й час початку та закінчення, тип доступу (публічний, білий список або за запрошенням) і варіанти голосування. Після збереження вибори матимуть статус «Чернетка», і ви зможете редагувати їх до публікації." },
        "q2": { "q": "Як запросити виборців?", "a": "На сторінці керування виборами можна згенерувати посилання-запрошення, код або QR-код. Також можна завантажити CSV-файл для визначення білого списку виборців, що обмежує участь лише зазначеними адресами електронної пошти." },
        "q3": { "q": "Коли закінчуються вибори?", "a": "Вибори завершуються автоматично після досягнення запланованої дати й часу закінчення — це обробляє фоновий планувальник. Після завершення хеш результатів записується в блокчейн, і результати стають доступними для авторизованих користувачів. Організатори не можуть змінити час закінчення після публікації виборів." }
      },
      "results": {
        "topic": "Результати та верифікація",
        "q1": { "q": "Як підраховуються результати?", "a": "Результати підраховуються автоматично після завершення виборів. Кожен варіант отримує кількість голосів і відсотковий розподіл. Фінальні дані результатів хешуються, і хеш записується до смарт-контракту Ethereum Sepolia, створюючи незмінний запис у блокчейні." },
        "q2": { "q": "Як перевірити результати в блокчейні?", "a": "На сторінці результатів ви побачите хеш транзакції для запису результатів у блокчейні. Натисніть на нього, щоб відкрити транзакцію на Etherscan Sepolia (sepolia.etherscan.io), де можна перевірити виклик контракту та хеш результатів незалежно — без облікового запису VoteMe." },
        "q3": { "q": "Що таке журнал аудиту?", "a": "Журнал аудиту — це незмінний, лише доповнюваний запис кожної значущої дії на платформі: створення виборів, зміни статусу, надсилання голосів і підрахунок результатів. Аудитори й адміністратори можуть переглядати журнал, щоб відновити повну історію будь-яких виборів." }
      },
      "security": {
        "topic": "Безпека та конфіденційність",
        "q1": { "q": "Чи є мій голос анонімним?", "a": "Голоси пов'язані з вашим обліковим записом внутрішньо для запобігання подвійному голосуванню, але на панелі результатів відображаються лише агреговані підрахунки — без зазначення того, хто за що проголосував. Персональні дані ніколи не зберігаються в блокчейні; лише криптографічні хеші та докази подій." },
        "q2": { "q": "Як працює верифікація блокчейну?", "a": "Коли вибори публікуються, хеш їхніх параметрів записується до смарт-контракту в Ethereum Sepolia. Після завершення туди ж записується хеш фінальних результатів. Оскільки записи блокчейну незмінні, будь-яка третя сторона може перевірити, що ні правила виборів, ні результати не були змінені після публікації." },
        "q3": { "q": "Які дані зберігаються в блокчейні?", "a": "Лише хеші та докази подій — ніяких персональних даних. Зокрема: хеш параметрів виборів на момент публікації та хеш даних результатів на момент фіналізації. Уся особисто ідентифікована інформація (імена, адреси електронної пошти, вибори) зберігається в приватній базі даних PostgreSQL і ніколи не публікується в блокчейні." }
      }
    }
  },
