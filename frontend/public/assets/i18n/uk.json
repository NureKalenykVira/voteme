  "faq": {
    "bannerText": "ЗАЛИШИЛИСЬ ПИТАННЯ? ВІДВІДАЙТЕ FAQ",
    "cta": {
      "text": "Залишились питання?",
      "btn": "Зв'язатись з нами"
