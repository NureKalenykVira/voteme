# Backend local development (.venv + uvicorn outside Docker).
# Place this file at backend/.env when running the backend on the host machine.
# For Docker Compose use the root-level .env.example instead.

# Local Postgres (running in Docker or on host). Use localhost when backend runs outside containers.
DATABASE_URL=postgresql+asyncpg://voteme:your_postgres_password@localhost:5432/voteme

# Auth
JWT_SECRET=generate_64_char_hex_with_openssl_rand
APP_SALT=generate_32_char_hex_with_openssl_rand
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Blockchain (Ethereum Sepolia)
BACKEND_PRIVATE_KEY=changeme_replace_with_eth_private_key
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/changeme
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# CORS
# JSON array of allowed origins for FastAPI CORSMiddleware.
CORS_ORIGINS=["http://localhost:4200","http://127.0.0.1:4200"]

# SMTP Email (use Mailpit for local dev: docker run -p 1025:1025 -p 8025:8025 axllent/mailpit)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@voteme.local
# TLS: for Mailpit local dev both are false; for real SMTP set SMTP_START_TLS=true (port 587) or SMTP_USE_TLS=true (port 465)
SMTP_START_TLS=false
SMTP_USE_TLS=false
FRONTEND_URL=http://localhost:4200
# Local timezone for chart/timeline label formatting (IANA name). Vote timestamps are stored in UTC.
APP_TIMEZONE=Europe/Kyiv

# Gmail SMTP (use Google App Password, not your main account password):
# 1. Enable 2FA on your Google account
# 2. Generate App Password at https://myaccount.google.com/apppasswords
# 3. Set SMTP_PASSWORD to the 16-char app password (no spaces)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your@gmail.com
# SMTP_PASSWORD=your_app_password_here
# SMTP_FROM=your@gmail.com
# SMTP_START_TLS=true
# SMTP_USE_TLS=false
